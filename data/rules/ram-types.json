{
  "id": "ram-crash-rules-core-draft",
  "status": "cleanedDraft",
  "source": {
    "book": "Dark Future Rulebook",
    "pages": [52, 53, 54, 55, 56, 57, 58],
    "extractionFile": "docs/rules/core/09-rams-and-crashes.md",
    "cleanedFile": "docs/rules/clean/rams-crashes.md"
  },
  "terms": {
    "rammer": "Vehicle executing the movement whose contact zone creates the collision.",
    "target": "Vehicle overlapped by the rammer contact zone.",
    "contactZone": "Track-space set supplied by track geometry for a movement stage."
  },
  "ramSequence": [
    "calculateContactZone",
    "detectVehicleOverlap",
    "leaveRammerInStartingPosition",
    "classifyRamType",
    "resolveSideswipeTestIfNeeded",
    "emitRamDamageRequests",
    "applySpeedAdjustment",
    "emitPostRamHazardRequests",
    "continueAfterRamMovementIfRequired"
  ],
  "damageFormulas": {
    "relativeSpeedFactorHit": {
      "hitCount": 1,
      "damageCharacteristic": "abs(faster.speedFactor - slower.speedFactor)",
      "noDamageWhenZero": true,
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [56]
      }
    },
    "combinedSpeedFactorHit": {
      "hitCount": 1,
      "damageCharacteristic": "rammer.speedFactor + target.speedFactor",
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [56]
      }
    },
    "combinedSpeedFactorDamage": {
      "hitCount": "rammer.speedFactor + target.speedFactor",
      "damageCharacteristic": "rammer.speedFactor + target.speedFactor",
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [56]
      }
    },
    "crashSpeedFactorDamage": {
      "hitCount": "vehicle.speedFactor",
      "damageCharacteristic": "vehicle.speedFactor",
      "campaignOnly": true,
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [58]
      }
    }
  },
  "ramTypes": [
    {
      "id": "headOn",
      "classification": {
        "directionRelation": "opposite",
        "laneOverlap": "oneOrBoth",
        "alsoWhen": [
          "targetIsWreck",
          "stationaryTargetFacingOppositeDirection",
          "targetAngledToGrid"
        ]
      },
      "damage": {
        "rammer": "combinedSpeedFactorDamage",
        "target": "combinedSpeedFactorDamage"
      },
      "speedAdjustment": {
        "kind": "setBothToZero"
      },
      "postRamHazards": [],
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [54, 56, 57]
      }
    },
    {
      "id": "shunt",
      "classification": {
        "directionRelation": "same",
        "laneOverlap": "oneOrBoth",
        "rammerMustBeFasterMph": true,
        "alsoWhen": [
          "stationaryNonWreckTargetFacingSameDirection"
        ]
      },
      "damage": {
        "rammer": "relativeSpeedFactorHit",
        "target": "relativeSpeedFactorHit",
        "noDamageWhenEqualSpeedFactor": true
      },
      "speedAdjustment": {
        "kind": "halveMphDifferenceRoundedUp",
        "rammer": "rammer.mph - ceil(abs(rammer.mph - target.mph) / 2)",
        "target": "target.mph + ceil(abs(rammer.mph - target.mph) / 2)"
      },
      "postRamHazards": [
        {
          "vehicle": "rammer",
          "safetyLimitMph": 40,
          "onlyIfMovingAndUnderControl": true
        },
        {
          "vehicle": "target",
          "safetyLimitMph": 40,
          "onlyIfMovingAndUnderControl": true,
          "panicBrakeResult": "ignoreTreatAsNoEffect"
        }
      ],
      "afterRamMovement": {
        "targetMovesThenRammerCompletesMove": true,
        "rammerMayTakeAction": false
      },
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [54, 56, 57]
      }
    },
    {
      "id": "sideswipeNeckAndNeck",
      "classification": {
        "requiresDeclaredRamAction": true,
        "mustFollowStraightAheadMove": true,
        "directionRelation": "same",
        "adjacentLaneSameSquareOrCurveEquivalent": true,
        "curveRequiresRammerFrontBehindTargetFront": true
      },
      "sideswipeTest": {
        "dice": {
          "kind": "d6",
          "count": 1,
          "reason": "sideswipeTest",
          "sourceRule": "core.rams.sideswipeTest"
        },
        "underControlModifier": "optimumControl",
        "outOfControlModifier": "adverseControl",
        "rammerModifier": 1,
        "compare": "higherTotalWins",
        "equalTotals": "draw"
      },
      "damage": {
        "loser": "relativeSpeedFactorHit",
        "draw": "relativeSpeedFactorHitToBoth"
      },
      "speedAdjustment": {
        "kind": "subtractBoth",
        "mph": 10
      },
      "postRamHazards": [
        {
          "vehicle": "loser",
          "safetyLimitMph": 40,
          "onlyIfMovingAndUnderControl": true
        }
      ],
      "drawHazardRule": "noPostRamHazardTest",
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [54, 55, 56, 57]
      }
    },
    {
      "id": "sideswipeOpposed",
      "classification": {
        "requiresDeclaredRamAction": true,
        "mustFollowStraightAheadMove": true,
        "directionRelation": "oppositeOrStationaryTarget",
        "adjacentLaneSameSquareOrCurveEquivalent": true,
        "curveRequiresRammerFrontBehindTargetFront": true
      },
      "sideswipeTest": {
        "dice": {
          "kind": "d6",
          "count": 1,
          "reason": "sideswipeTest",
          "sourceRule": "core.rams.sideswipeTest"
        },
        "underControlModifier": "optimumControl",
        "outOfControlModifier": "adverseControl",
        "rammerModifier": 1,
        "compare": "higherTotalWins",
        "equalTotals": "draw"
      },
      "damage": {
        "loser": "combinedSpeedFactorHit",
        "draw": "combinedSpeedFactorHitToBoth"
      },
      "speedAdjustment": {
        "kind": "subtractBoth",
        "mph": 20
      },
      "postRamHazards": [
        {
          "vehicle": "winner",
          "safetyLimitMph": 40,
          "onlyIfMovingAndUnderControl": true
        },
        {
          "vehicle": "loser",
          "safetyLimitMph": 20,
          "onlyIfMovingAndUnderControl": true
        }
      ],
      "drawHazardRule": "noPostRamHazardTest",
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [54, 55, 56, 57]
      }
    }
  ],
  "crashes": {
    "ordinaryCrash": {
      "trigger": "movingVehicleContactZoneLeavesRoadSurfaceOrHitsObstacle",
      "voluntaryActionMayCauseCrash": false,
      "removeFromTacticalPlay": true,
      "damage": "crashSpeedFactorDamage",
      "damageRequiredWhen": "campaignOrScenarioTracksRepairState",
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [58]
      }
    },
    "curveNoDriverCrash": {
      "trigger": "vehicleEndsMoveOnCurvedTrackWithNoDriver",
      "removeFromTacticalPlay": true,
      "ignoreNearbyContacts": true,
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [58]
      }
    },
    "coreCurveSpinCrash": {
      "trigger": "vehicleForcedToRotateOnCurvedTrack",
      "rulesMode": "core",
      "removeFromTacticalPlay": true,
      "ignoreNearbyContacts": true,
      "overriddenBy": "whiteLineFeverAdvancedCurveSpins",
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [58]
      }
    }
  },
  "stagedMovementCollisionNotes": {
    "skidSpinRollStages": [
      "forwardMove",
      "driftSkid",
      "spin",
      "roll"
    ],
    "checkContactBeforeEachStage": true,
    "collisionEndsCurrentStageSequence": true,
    "spinRotationCollisionClassifiesAs": "sideswipe",
    "rollingVehicleBlocked": "resolveCollisionAtCurrentSpeedThenRollAndStop",
    "source": {
      "book": "Dark Future Rulebook",
      "pages": [57]
    }
  },
  "ambiguities": [
    {
      "id": "contact-zone-diagram-tracing",
      "status": "partiallyResolvedByUserRuling",
      "notes": "Curve ram/shunt contact uses any shared occupied lane; curve sideswipe uses adjacent front-half contact inward or outward. Edge handling follows the clarified lane boundary rule: leaving lanes 1-8 crashes.",
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [52, 53]
      }
    },
    {
      "id": "neck-and-neck-draw-hazard",
      "status": "resolvedByUserRuling",
      "notes": "Damage draw affects both vehicles; no post-ram hazard test is required on a draw.",
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [56, 57]
      }
    },
    {
      "id": "ram-damage-facing",
      "status": "resolvedByUserRuling",
      "notes": "Head-on hits front. Shunt hits attacker front and defender rear. Sideswipe hits relative sides; if unclear, roll D6: 1-2 roof, 3 left side, 4 right side, 5-6 front.",
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [34, 56]
      }
    }
  ]
}
