  "panicBraking": {
    "speedLossMph": "5 * hazardTotal",
    "appliesImmediately": true,
    "preventsActionsForRestOfPhase": true,
    "allowance": {
      "ordinaryPhase": "vehicle.currentBraking - brakingAlreadyUsedThisPhase",
      "lateTurnHit": "vehicle.currentBraking across rest of turn"
    },
    "insufficientAllowanceEffect": "controlLoss"
  },
  "multipleHazards": {
    "order": "descendingSafetyLimit",
    "oilAlwaysLast": true,
    "skipIfCurrentSpeedAtOrBelowLimit": true,
    "stopAfterControlLoss": true
  },
  "advancedSpin": {
    "source": {
      "book": "White Line Fever",
      "pages": [10]
    },
    "steps": [
      "skidTestBeforeStraightAheadMove",
      "straightAheadMoveWithOptionalDriftSkid",
      "spinTest"
    ],
    "skidTest": {
      "dice": { "kind": "d6", "count": 2 },
      "driftOccursWhenFirstDieOdd": true,
      "directionWhenDriftOccurs": {
        "oddSecondDie": "left",
        "evenSecondDie": "right"
      },
      "leftRightReference": "directionOfTravel"
    },
    "collisionInterruptsMove": true,
    "driftSkidCollisionRamType": "sideswipe",
    "oppositeDirectionDriftSkidCollisionRamType": "opposedSideswipe",
    "alreadySpunSpinTemplate": {
      "source": "user-supplied spin template image",
      "alignment": "Align the template with the front of the vehicle.",
      "orientation": "12+ is straight ahead from the vehicle front. Red values run clockwise from the front; blue values run counter-clockwise from the front.",
      "spinTest": {
        "dice": { "kind": "d6", "count": 1 },
        "odd": "blueCounterClockwise",
        "even": "redClockwise"
      },
      "rowsByColour": {
        "redClockwise": [
          { "range": { "min": 2, "max": 3 }, "speedLossMph": 40, "angleOffsetDegrees": 45 },
          { "range": { "min": 4, "max": 5 }, "speedLossMph": 20, "angleOffsetDegrees": 90 },
          { "range": { "min": 6, "max": 7 }, "speedLossMph": 20, "angleOffsetDegrees": 135 },
          { "range": { "min": 8, "max": 8 }, "speedLossMph": 30, "angleOffsetDegrees": 180 },
          { "range": { "min": 9, "max": 9 }, "speedLossMph": 40, "angleOffsetDegrees": 225 },
          { "range": { "min": 10, "max": 10 }, "speedLossMph": 40, "angleOffsetDegrees": 270 },
          { "range": { "min": 11, "max": 11 }, "speedLossMph": 40, "angleOffsetDegrees": 315 },
          { "range": { "min": 12 }, "speedLossMph": 40, "angleOffsetDegrees": 0 }
        ],
        "blueCounterClockwise": [
          { "range": { "min": 2, "max": 3 }, "speedLossMph": 20, "angleOffsetDegrees": 315 },
          { "range": { "min": 4, "max": 5 }, "speedLossMph": 20, "angleOffsetDegrees": 270 },
          { "range": { "min": 6, "max": 7 }, "speedLossMph": 20, "angleOffsetDegrees": 225 },
          { "range": { "min": 8, "max": 8 }, "speedLossMph": 30, "angleOffsetDegrees": 180 },
          { "range": { "min": 9, "max": 9 }, "speedLossMph": 40, "angleOffsetDegrees": 135 },
          { "range": { "min": 10, "max": 10 }, "speedLossMph": 40, "angleOffsetDegrees": 90 },
          { "range": { "min": 11, "max": 11 }, "speedLossMph": 40, "angleOffsetDegrees": 45 },
          { "range": { "min": 12 }, "speedLossMph": 40, "angleOffsetDegrees": 0 }
        ]
      },
      "defaultColour": "redClockwise",
      "unimplementedRows": [
        {
          "label": "facing/reorientation coordinates",
          "reason": "The speed-loss table is transcribed. Exact final facing and grid realignment still need to be linked to tactical map coordinates."
        }
      ]
    }
  },
  "spinningOnCurves": {
    "source": {
      "book": "White Line Fever",
      "pages": [11]
    },
    "enabled": true,
    "positionReference": "vehicleCentrePoint",
    "unevenLaneReference": "outsideLaneSpaceDividers",
    "driftSkidInwardEffect": "straightSkid",
    "otherDriftSkidEffect": "driftSkidOutward",
    "status": "draft"
  },
  "rolling": {
    "core": {
      "source": {
        "book": "Dark Future Rulebook",
        "pages": [46]
      },
      "preRollSteps": ["skid", "spin"],
      "wreckedImmediately": true,
      "damage": {
        "hitCount": "currentSpeedFactor",
        "damagePerHit": "currentSpeedFactor",
        "criticalFacing": "roof"
      },
      "ignoreSpinTemplateSpeedReduction": true,
      "finalSpeedMph": 0,
      "remainsAsWreck": true
    },
    "whiteLineFever": {
      "source": {
        "book": "White Line Fever",
        "pages": [11]
      },
      "preRollSteps": ["advancedSpinMove"],
      "continuesAcrossPhasesUntilSpeedZero": true,
      "additionalSpeedLossEachRollingPhaseMph": 10,
      "damageFacingRoll": [
        { "range": { "min": 1, "max": 2 }, "facing": "roof" },
        { "range": { "min": 3, "max": 4 }, "facing": "front" },
        {
          "range": { "min": 5, "max": 5 },
          "facing": "side",
          "sideRoll": { "odd": "left", "even": "right" }
        },
        { "range": { "min": 6, "max": 6 }, "facing": "floor" }
      ],
      "damage": {
        "hitCount": "speedFactorAfterSpinAndRollSpeedLoss",
        "damagePerHit": "speedFactorAfterSpinAndRollSpeedLoss",
        "criticalFacing": "damageFacingRoll"
      }
    }
  },
  "ambiguities": [
    {
      "id": "ambiguity.uTurnSafetyLimit",
      "sourcePage": 38,
      "description": "Page 38 OCR suggests a U-turn safety limit, but page 40 gives clear automatic control loss above 30 mph. Confirm exact hazard behaviour for U-turns at 11-30 mph."
    },
    {
      "id": "ambiguity.debrisSafetyLimit",
      "sourcePage": 38,
      "description": "Road hazard debris safety limit is not readable enough from OCR."
    },
    {
      "id": "ambiguity.coreSkidSpinTemplates",
      "sourcePages": [43, 44, 45],
      "description": "Core skid/spin template values and orientation diagrams require image proofread before implementation."
    },
    {
      "id": "ambiguity.passiveMoveOffException",
      "sourcePage": 40,
      "description": "OCR mentions a passive weapon exception tested when moving off the counter but does not reliably identify the passive."
    }
  ]
}
