{
  "id": "hazards-control-loss-draft",
  "status": "draft",
  "source": {
    "book": "Dark Future Rulebook",
    "pages": [38, 39, 40, 41, 42, 43, 44, 45, 46],
    "extractionFile": "docs/rules/core/08-hazards-control-loss-tests.md",
    "supplement": {
      "book": "White Line Fever",
      "pages": [10, 11],
      "extractionFile": "docs/rules/white-line-fever/02-advanced-hazards.md"
    }
  },
  "hazardRoll": {
    "dice": { "kind": "d6", "count": 1 },
    "formula": [
      { "id": "die", "operation": "addRoll" },
      {
        "id": "excessSpeed",
        "operation": "add",
        "value": "ceil(max(0, mph - safetyLimitMph) / 10)"
      },
      {
        "id": "optimumControl",
        "operation": "subtract",
        "value": "max(vehicle.handling, driver.driveSkill)"
      }
    ],
    "results": [
      {
        "id": "hazard.ok",
        "range": { "max": 0 },
        "effect": "ok"
      },
      {
        "id": "hazard.panicBrake",
        "range": { "min": 1, "max": 4 },
        "effect": "panicBrake",
        "speedLossMph": "5 * total",
        "usesBrakingAllowance": true
      },
      {
        "id": "hazard.controlLoss",
        "range": { "min": 5 },
        "effect": "controlLoss"
      }
    ]
  },
  "controlLossTest": {
    "dice": { "kind": "d6", "count": 1 },
    "formula": [
      { "id": "die", "operation": "addRoll" },
      { "id": "speedFactor", "operation": "add", "value": "vehicle.speedFactor" },
      {
        "id": "adverseControl",
        "operation": "subtract",
        "value": "min(vehicle.handling, driver.driveSkill)"
      },
      {
        "id": "zeroHandlingOrNoDriver",
        "operation": "add",
        "value": 2,
        "condition": "vehicle.handling == 0 || driver == null"
      }
    ],
    "results": [
      {
        "id": "controlLoss.regainControl",
        "range": { "max": 1 },
        "effect": "regainControlAfterStraightMove",
        "usesAction": true,
        "takesHazardsDuringCompulsoryMove": true
      },
      {
        "id": "controlLoss.skidRegainControl",
        "range": { "min": 2, "max": 3 },
        "effect": "skidThenRegainControl",
        "usesSkidTest": true
      },
      {
        "id": "controlLoss.skidRemainOutOfControl",
        "range": { "min": 4, "max": 5 },
        "effect": "skidRemainOutOfControl",
        "usesSkidTest": true
      },
      {
        "id": "controlLoss.spin",
        "range": { "min": 6, "max": 7 },
        "effect": "spin",
        "usesSkidTest": true,
        "usesSpinTest": true,
        "suppressesFutureControlLossTests": true
      },
      {
        "id": "controlLoss.roll",
        "range": { "min": 8 },
        "effect": "roll",
        "usesSkidTest": true,
        "usesSpinTest": true
      }
    ]
  },
