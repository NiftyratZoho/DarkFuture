  "contractBridge": {
    "id": "deadMansCurve.contractToScenarioBridge",
    "status": "draftNeedsCampaignApproachProofread",
    "inputFromCampaign": [
      "contractId",
      "campaignSequenceId",
      "attackerUnitId",
      "defenderUnitId",
      "engagementType",
      "eligibleDriverIds",
      "eligibleVehicleIds",
      "approachModifiers",
      "cruisingRestrictions",
      "engagementObjective"
    ],
    "outputToTactical": [
      "engagementId",
      "scenarioId",
      "sideRoles",
      "trackSetup",
      "deploymentZones",
      "initialSpeeds",
      "participantVehicleIds",
      "participantDriverIds",
      "scenarioState",
      "victoryCondition",
      "aiSetup"
    ],
    "engagementTypeMappings": [
      {
        "engagementType": "pursuit",
        "scenarioPattern": "leadChase",
        "notes": "Usually maps target/defender to lead and attacker to chase; final mapping depends on approach rules."
      },
      {
        "engagementType": "intercept",
        "scenarioPattern": "opposedFacingOrCrossing",
        "notes": "Core Game Eight is the nearest explicit template."
      },
      {
        "engagementType": "ambush",
        "scenarioPattern": "ambush",
        "status": "needsProofread",
        "notes": "Dead Man's Curve setup text is OCR-damaged."
      }
    ],
    "mustNotApplyCampaignPostEngagement": true,
    "source": {
