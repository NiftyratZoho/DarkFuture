      { "range": { "max": 1 }, "effect": "regainControl" },
      { "range": { "min": 2, "max": 3 }, "effect": "skidAndRegainControl" },
      { "range": { "min": 4, "max": 5 }, "effect": "skidRemainOutOfControl" },
      { "range": { "min": 6 }, "effect": "roll" }
    ],
    "source": { "book": "Dark Future Rulebook", "pages": [70] }
  },
  "bikeRolling": {
    "immediateCrashAtOrAboveMph": 81,
    "rollAtOrBelowMph": 80,
