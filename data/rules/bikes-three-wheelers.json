    "rider": [
      { "range": [1, 2], "effect": "hurtAsCar" },
      { "range": [3, 4], "effect": "injuredAsCar" },
      { "roll": 5, "effect": "limbDisabledAsCar" },
      { "roll": 6, "effect": "koNoRider", "bikeRollsOnNextMove": true }
