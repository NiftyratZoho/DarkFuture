          { "roll": 1, "facing": "leftSide" },
          { "roll": 2, "facing": "rightSide" },
          { "roll": 3, "facing": "roof" },
          { "roll": 4, "facing": "floor" },
          { "roll": 5, "facing": "front" },
          { "roll": 6, "facing": "rear" }
        ]
      },
      "finalSpeedMph": 0,
      "fallenPlacement": "onSideAtAngleToGrid",
      "ifTerminalOrRiderKo": "wreck",
      "ifSurvives": "mayBePickedUpAtStartOfNextMove"
    },
    "source": { "book": "Dark Future Rulebook", "pages": [70] }
  },
  "bikeCriticalTables": {
    "bodywork": [
      { "roll": 1, "effect": "transmissionCheck", "check": "d6 + hitDamage >= 6", "successEffect": "accelerationToZero", "failureEffect": "wasted" },
